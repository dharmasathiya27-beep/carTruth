# Frontend Environment Variables (.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend Environment Variables (.env in backend/)
APP_ENV=development
USE_MOCK_DATA=true
ALLOW_MOCK_MOT_FALLBACK=true

# DVLA Vehicle Enquiry API
DVLA_API_KEY=
DVLA_API_BASE_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# DVSA MOT History API
DVSA_CLIENT_ID=
DVSA_CLIENT_SECRET=
DVSA_API_KEY=
DVSA_SCOPE_URL=
DVSA_TOKEN_URL=
DVSA_API_BASE_URL=https://history.mot.api.gov.uk/v1/trade/vehicles/registration

# Logging
# LOG_LEVEL=info
